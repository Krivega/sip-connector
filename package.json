{
  "name": "sip-connector",
  "version": "28.12.0",
  "description": "Module for connect to Vinteo server",
  "keywords": [
    "webrtc",
    "Vinteo"
  ],
  "bugs": {
    "url": "https://github.com/Krivega/sip-connector/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Krivega/sip-connector.git"
  },
  "license": "MIT",
  "author": {
    "name": "Krivega Dmitriy",
    "email": "mr.krivega@gmail.com",
    "url": "https://krivega.com"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./doMock": {
      "types": "./dist/doMock.d.ts",
      "import": "./dist/doMock.js",
      "require": "./dist/doMock.cjs",
      "default": "./dist/doMock.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && node ./scripts/prune-dist.cjs",
    "build:demo": "vite build --config vite.demo.config.ts",
    "cert": "rm -rf .cert && mkdir -p .cert && mkcert -key-file ./.cert/key.pem -cert-file ./.cert/cert.pem 'localhost'",
    "docs:check": "node ./scripts/docs-check.cjs",
    "lint": "yarn lint:ts && yarn lint:js && yarn docs:check",
    "lint:js": "yarn lint:js:src && yarn lint:js:demo && yarn lint:js:e2e",
    "lint:js:demo": "eslint demo --ext ts,tsx --report-unused-disable-directives --max-warnings 0 --cache --cache-strategy=content",
    "lint:js:src": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0 --cache --cache-strategy=content",
    "lint:js:e2e": "eslint e2e --ext ts,tsx --report-unused-disable-directives --max-warnings 0 --cache --cache-strategy=content",
    "lint:ts": "tsc",
    "prepare": "husky",
    "prepublishOnly": "yarn build",
    "preview": "vite preview",
    "release": "standard-version && npm run release:publish && npm publish --access=public --registry=https://registry.npmjs.org/",
    "release:alpha": "standard-version --prerelease alpha && npm run release:publish && npm publish --tag alpha --registry=https://registry.npmjs.org/",
    "release:major": "standard-version --release-as major && npm run release:publish && npm publish --access=public --registry=https://registry.npmjs.org/",
    "release:pre": "standard-version --prerelease && npm run release:publish && npm publish --tag prerelease --registry=https://registry.npmjs.org/",
    "release:publish": "git push --follow-tags",
    "start": "vite --config vite.demo.config.ts",
    "start:builded": "yarn build:demo && http-server demoDist -c-1 -o --cors",
    "test": "jest",
    "test:ci": "cross-env CI=true jest --no-cache --coverage",
    "test:coverage": "yarn test:ci || node ./scripts/showCoverageReport.cjs",
    "test:e2e": "playwright test",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@krivega/cancelable-promise": "^1.1.4",
    "@krivega/jssip": "^6.1.1",
    "@krivega/timeout-requester": "^1.0.0",
    "debug": "^4.4.3",
    "events-constructor": "^2.3.1",
    "lodash": "^4.18.1",
    "mobx": "^6.16.1",
    "mobx-state-tree": "^7.2.0",
    "repeated-calls": "^2.4.0",
    "sequent-promises": "^2.0.1",
    "stack-promises": "^2.0.4",
    "ts-debounce": "^5.0.1",
    "ua-parser-js": "^2.0.10",
    "webrtc-mock": "^1.2.2",
    "xstate": "^5.32.2"
  },
  "devDependencies": {
    "@babel/preset-typescript": "^8.0.1",
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@eslint/compat": "^2.1.0",
    "@krivega/eslint-config": "^1.1.23",
    "@playwright/test": "^1.61.0",
    "@types/debug": "^4.1.13",
    "@types/dom-mediacapture-transform": "^0.1.11",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.24",
    "@types/node": "^26.0.0",
    "cross-env": "^10.1.0",
    "http-server": "^14.1.1",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "jest-extended": "^7.0.0",
    "jest-junit": "^17.0.0",
    "lint-staged": "^17.0.8",
    "prettier": "^3.8.4",
    "standard-version": "^9.5.0",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "tsc-files": "^1.1.4",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vite-plugin-dts": "^5.0.2",
    "webrtc-adapter": "^9.0.6"
  },
  "peerDependencies": {
    "@krivega/cancelable-promise": "^1.1.4",
    "@krivega/jssip": "^6.1.1",
    "@krivega/timeout-requester": "^1.0.0",
    "debug": "^4.4.3",
    "events-constructor": "^2.3.1",
    "lodash": "^4.18.1",
    "repeated-calls": "^2.4.0",
    "sequent-promises": "^2.0.1",
    "stack-promises": "^2.0.4",
    "ts-debounce": "^5.0.1",
    "ua-parser-js": "^2.0.9",
    "webrtc-mock": "^1.2.2",
    "xstate": "^5.32.2"
  },
  "packageManager": "yarn@1.22.22"
}
